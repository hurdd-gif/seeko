{
  "//": "Scoped declaration emit for the design-sync bundle. Produces real .d.ts",
  "//2": "for the ui/* primitives so the design agent codes against true prop",
  "//3": "contracts. Output → ../types/ (findTypesRoot picks up 'types'). Run:",
  "//4": "  npx tsc -p .design-sync/tsconfig.dts.json",
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "sourceMap": false,
    "incremental": false,
    "composite": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "baseUrl": "..",
    "paths": { "@/*": ["src/*"] },
    "rootDir": "..",
    "outDir": "../types"
  },
  "include": [
    "../src/components/ui/AnimatedNumber.tsx",
    "../src/components/ui/avatar.tsx",
    "../src/components/ui/badge.tsx",
    "../src/components/ui/button.tsx",
    "../src/components/ui/card.tsx",
    "../src/components/ui/checkbox.tsx",
    "../src/components/ui/date-picker.tsx",
    "../src/components/ui/dialog.tsx",
    "../src/components/ui/dropdown-menu.tsx",
    "../src/components/ui/alert-dialog.tsx",
    "../src/components/ui/empty-state.tsx",
    "../src/components/ui/gradient-avatar.tsx",
    "../src/components/ui/input.tsx",
    "../src/components/ui/label.tsx",
    "../src/components/ui/mono-badge.tsx",
    "../src/components/ui/progress.tsx",
    "../src/components/ui/select.tsx",
    "../src/components/ui/separator.tsx",
    "../src/components/ui/switch.tsx",
    "../src/components/ui/textarea.tsx"
  ],
  "exclude": ["../node_modules"]
}
